load("@rules_python//python:defs.bzl", "py_binary", "py_library")
load(":defs.bzl", "py_codegen")

py_codegen(
    name = "gen",
    srcs = ["gen.py.tmpl"],
)

# A library whose srcs are generated by another rule.
py_library(
    name = "wrapped",
    srcs = [":gen"],
)

py_binary(
    name = "main",
    srcs = ["main.py"],
    deps = [":wrapped"],
)
