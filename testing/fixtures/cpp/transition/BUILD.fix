load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load(":foo_bar.bzl", "foo_bar_binary")

cc_binary(
    name = "main",
    srcs = [":main.cc"],
)

foo_bar_binary(
    name = "foo_bar",
    dep = ":main",
)

genrule(
    name = "exec_tool",
    outs = ["exec_tool.sh"],
    cmd = "echo '#!/bin/sh' > $@ && chmod +x $@",
    executable = True,
)

genrule(
    name = "exec_main",
    outs = ["exec_main.out"],
    cmd = "$(execpath :exec_tool) > $@",
    tools = [":exec_tool"],
)
