load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_cc//cc/toolchains:cc_toolchain.bzl", "cc_toolchain")
load(":cc_toolchain_config.bzl", "cc_toolchain_config")

# empty filegroup reused for every cc_toolchain file attribute
filegroup(
    name = "empty",
    srcs = [],
)

cc_toolchain_config(
    name = "sdp_toolchain_config",
)

cc_toolchain(
    name = "sdp_cc_toolchain",
    all_files = ":empty",
    ar_files = ":empty",
    compiler_files = ":empty",
    dwp_files = ":empty",
    linker_files = ":empty",
    objcopy_files = ":empty",
    strip_files = ":empty",
    toolchain_config = ":sdp_toolchain_config",
)

# empty exec/target constraints match any platform during toolchain resolution.
toolchain(
    name = "sdp_toolchain",
    exec_compatible_with = [],
    target_compatible_with = [],
    toolchain = ":sdp_cc_toolchain",
    toolchain_type = "@bazel_tools//tools/cpp:toolchain_type",
)

cc_binary(
    name = "main",
    srcs = ["main.cc"],
)
